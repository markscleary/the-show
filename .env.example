# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# ──────────────────────────────────────────────────────────────────────────────
# Telegram — dedicated urgent-contact bot
# Create via BotFather: https://t.me/BotFather → /newbot
# Get a user's numeric ID by messaging @userinfobot
# ──────────────────────────────────────────────────────────────────────────────
URGENT_TELEGRAM_BOT_TOKEN=

# Numeric Telegram user IDs (not usernames) of authorised approvers
URGENT_CONTACT_PRIMARY_TELEGRAM_USER_ID=
URGENT_CONTACT_ALTERNATE_TELEGRAM_USER_ID=

# Display handles used in show YAML contacts config (numeric user_id is the actual handle)
URGENT_CONTACT_PRIMARY_TELEGRAM_HANDLE=@mark
URGENT_CONTACT_ALTERNATE_TELEGRAM_HANDLE=@greg

# ──────────────────────────────────────────────────────────────────────────────
# Email — Gmail SMTP with App Password
# Enable 2FA on the Gmail account, then:
# Google Account → Security → App Passwords → create one for "Mail / Mac"
# ──────────────────────────────────────────────────────────────────────────────
URGENT_SMTP_HOST=smtp.gmail.com
URGENT_SMTP_PORT=587
URGENT_SMTP_USERNAME=youraddress@gmail.com
URGENT_SMTP_PASSWORD=               # 16-char App Password (no spaces)
URGENT_EMAIL_FROM=youraddress@gmail.com

# Random secret for HMAC-signing email action links — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
URGENT_EMAIL_SIGNING_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Signed-link HTTP endpoint (link_server.py)
# Session 4: localhost only. Production: put behind a reverse proxy or Cloudflare Tunnel.
# ──────────────────────────────────────────────────────────────────────────────
URGENT_LINK_ENDPOINT_HOST=127.0.0.1
URGENT_LINK_ENDPOINT_PORT=5099

# ──────────────────────────────────────────────────────────────────────────────
# WhatsApp — Meta WhatsApp Business Cloud API (SKELETON — Session 4)
# Full onboarding docs in urgent_contact/channels/whatsapp.py class docstring.
# Onboarding can take 1–7 days; Telegram is recommended for immediate use.
# ──────────────────────────────────────────────────────────────────────────────
URGENT_WHATSAPP_PHONE_NUMBER_ID=    # from Meta App Dashboard → WhatsApp → Getting Started
URGENT_WHATSAPP_ACCESS_TOKEN=       # system user permanent token
URGENT_WHATSAPP_VERIFY_TOKEN=       # any random string you choose for webhook verification

# ──────────────────────────────────────────────────────────────────────────────
# SMS — Twilio
# Sign up at https://twilio.com; Account SID + Auth Token in Console Dashboard.
# Trial accounts can only send to verified numbers — upgrade for unrestricted use.
# Configure your Twilio number's inbound webhook to POST to:
#   http://<ngrok-url>/twilio-webhook
# ──────────────────────────────────────────────────────────────────────────────
URGENT_TWILIO_ACCOUNT_SID=
URGENT_TWILIO_AUTH_TOKEN=
URGENT_TWILIO_FROM_NUMBER=          # E.164 format, e.g. +15005550006
